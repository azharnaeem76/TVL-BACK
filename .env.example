# Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/tvl_db
SYNC_DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/tvl_db

# Auth
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Ollama (local LLM - free, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Set this to your custom models directory (default: Ollama's default location)
# OLLAMA_MODELS_DIR=D:\AI_Models\ollama

# HuggingFace model cache (embedding model storage)
HF_HOME=D:\AI_Models\huggingface

# Embedding model (runs locally)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@tvl.pk
FROM_NAME=TVL - The Value of Law

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Socket.IO (real-time notifications & messaging)
# No extra config needed - runs on the same port as FastAPI
# Start with: uvicorn app.main:socket_app --reload

# Vector search
SIMILARITY_THRESHOLD=0.3
MAX_SEARCH_RESULTS=10
